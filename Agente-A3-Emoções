        "jsCode": "let dadosCompra = $input.item.json.output;\n\ntry {\n  if (typeof dadosCompra === 'string') {\n \n    dadosCompra = dadosCompra.replace(/```json|```/g, '').trim();\n    \n  \n    if (!dadosCompra.startsWith('[') && !dadosCompra.startsWith('{')) {\n  \n       return [{ json: { stop_execution: true, message: \"A IA retornou texto em vez de dados estruturados.\" } }];\n    }\n    \n \n    dadosCompra = JSON.parse(dadosCompra);\n  }\n\n\n  const compra = Array.isArray(dadosCompra) ? dadosCompra[0] : dadosCompra;\n\n  if (!compra || (!compra.CLIENTE && !compra.PRODUTO && !compra.cliente && !compra.produto)) {\n    return [{ json: { stop_execution: true, message: \"Dados insuficientes ou inválidos para inserção.\" } }];\n  }\n\n\n  return [{\n    json: {\n      DATA: compra.DATA || compra.data || new Date().toLocaleDateString('pt-BR'),\n      CLIENTE: compra.CLIENTE || compra.cliente || \"\",\n      PRODUTO: compra.PRODUTO || compra.produto || \"\",\n      VALOR: parseFloat(compra.VALOR || compra.valor) || 0\n    }\n  }];\n\n} catch (error) {\n\n  return [{ json: { stop_execution: true, error: true, message: error.message } }];\n}"
